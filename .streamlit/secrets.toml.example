# ─────────────────────────────────────────────────────────────────
# .streamlit/secrets.toml.example
# Bu dosyayı kopyalayıp secrets.toml olarak kaydedin.
# secrets.toml asla Git'e gönderilmemeli!
# ─────────────────────────────────────────────────────────────────

# Supabase veya başka bir PostgreSQL sunucusunun bağlantı adresi.
# Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL = "postgresql://postgres:[SIFRENIZ]@db.[PROJE_ID].supabase.co:5432/postgres"
